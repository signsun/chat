    //doxygen注释设置
    "doxdocgen.c.triggerSequence": "///",
    "doxdocgen.c.firstLine": "/**",
    "doxdocgen.c.lastLine": "**/",
    "doxdocgen.cpp.ctorText": "Construct a new {name} object",
    "doxdocgen.cpp.dtorText": "Destroy the {name} object",
